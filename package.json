{
  "name": "agent-session-manager",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "version:sync": "node scripts/sync-version.mjs",
    "dev": "node scripts/sync-version.mjs && vite",
    "build": "node scripts/sync-version.mjs && tsc && vite build",
    "preview": "vite preview",
    "tauri": "node scripts/sync-version.mjs && tauri",
    "release": "node scripts/sync-version.mjs && tauri build --bundles nsis",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepSeek Session Manager",
  "version": "0.1.0",
  "identifier": "com.cap.deepseek-session-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepSeek Session Manager",
        "width": 1220,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
